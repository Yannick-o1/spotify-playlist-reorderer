SPOTIFY_CLIENT_ID=your_spotify_app_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_app_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token
SPOTIFY_PLAYLIST_ID=spotify_playlist_id_or_url

# Pick one method, use random-eccentric, or combine up to 3 methods:
# ORDER_MODE=random-eccentric
# ORDER_MODE=second-letter-reverse-alpha
# ORDER_MODE=combo:vowel-density,least-popular-first,duration-long-short
ORDER_MODE=random-eccentric

# Optional random seed for reproducible shuffles. Leave blank for fresh randomness.
ORDER_SEED=

# Scheduled GitHub runs use this date to decide the every-other-day cadence.
EVERY_OTHER_DAY_ANCHOR=2026-04-29
